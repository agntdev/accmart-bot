[
  {
    "name": "/start replies with the welcome + main menu",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "Menu:main re-renders the main menu",
    "steps": [
      {
        "send": { "callback": "menu:main" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "Unknown message gets fallback reply",
    "steps": [
      {
        "send": { "text": "hello world" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Sorry, I didn't understand that. Try /help." }
          }
        ]
      }
    ]
  }
]
