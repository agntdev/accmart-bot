  {
    "name": "Change admin ID shows old and new IDs on update",
    "steps": [
      {
        "send": { "callback": "admin:menu" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "⚙️ Admin Setup\n\nFirst, send your Telegram user ID to set as owner.\nYou can find it via @userinfobot." }
          }
        ]
      },
      {
        "send": { "text": "1" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Owner set to 1." }
          }
        ]
      },
      {
        "send": { "text": "/set_admin_id" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Send the new admin Telegram ID (numeric) or 'cancel'." }
          }
        ]
      },
      {
        "send": { "text": "111" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Admin ID set to 111." }
          }
        ]
      },
      {
        "send": { "text": "Change admin ID" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Current admin ID: 111\n\nSend the new admin Telegram ID (numeric) or 'cancel'." }
          }
        ]
      },
      {
        "send": { "text": "222" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Admin ID updated.\n\nOld: 111\nNew: 222" }
          }
        ]
      }
    ]
  },
  {
    "name": "Cancel during set_admin_id flow cancels operation",
