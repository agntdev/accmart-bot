[
  {
    "name": "/set_admin_id rejects non-owner",
    "steps": [
      {
        "send": { "text": "/set_admin_id" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "You don't have access to admin controls." }
          }
        ]
      }
    ]
  },
  {
    "name": "Change admin ID text alias rejects non-owner",
    "steps": [
      {
        "send": { "text": "Change admin ID" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "You don't have access to admin controls." }
          }
        ]
      }
    ]
  },
  {
    "name": "/set_admin_id prompts for new admin ID",
    "steps": [
      {
        "send": { "callback": "admin:menu" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": { "text": "⚙️ Admin Setup\n\nFirst, send your Telegram user ID to set as owner.\nYou can find it via @userinfobot." }
          }
        ]
      },
      {
        "send": { "text": "1" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Owner set to 1." }
          }
        ]
      },
      {
        "send": { "text": "/set_admin_id" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Send the new admin Telegram ID (numeric) or 'cancel'." }
          }
        ]
      }
    ]
  },
